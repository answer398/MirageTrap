APP_PORT=15000
HOST_APP_PORT=15000
HOST_WEB_HONEYPOT_PORT=18080
CORS_ALLOWED_ORIGINS=http://127.0.0.1:15173,http://localhost:15173
SECRET_KEY=replace-with-strong-random-secret-64+
JWT_SECRET_KEY=replace-with-strong-random-jwt-secret-64+
DATABASE_URL=postgresql+psycopg2://honeypot:honeypot@postgres:5432/honeypot_db
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
INGEST_TOKEN=replace-with-long-random-ingest-token
HONEYPOT_CONTROL_TOKEN=replace-with-long-random-control-token
SESSION_AGGREGATION_MINUTES=30
HONEYPOT_ORCHESTRATION_ENABLED=false
HONEYPOT_DOCKER_HOST=
HONEYPOT_DOCKER_NETWORK=bridge
HONEYPOT_DOCKER_READ_ONLY_ROOTFS=true
WEB_HONEYPOT_ID=hp-web-compose-001
WEB_HONEYPOT_MAX_BODY=4096
EVIDENCE_STORAGE_DRIVER=local
EVIDENCE_LOCAL_PATH=instance/evidence
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=miragetrap-evidence
MINIO_SECURE=false
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=miragetrap
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
REALTIME_RECENT_LIMIT=300
REALTIME_SUBSCRIBER_QUEUE_SIZE=200
ALERT_HIGH_RISK_ENABLED=true
ALERT_TRIGGER_LEVELS=high,critical
ALERT_SUPPRESSION_SECONDS=300
ALERT_MAX_RETRIES=3
ALERT_RETRY_BACKOFF_SECONDS=3
ALERT_RETRY_DUE_BATCH_LIMIT=50
ALERT_RETRY_LOOP_INTERVAL_SECONDS=30
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=3
AUTO_CREATE_TABLES=false
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=replace-with-strong-admin-password
